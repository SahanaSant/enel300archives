while True:
    if uart.any():
        data = uart.readline()
        if data:
            incoming = data.decode('utf-8').strip()
            print("Slave recieved", incoming)
            if (incoming == "pressed"):
                print("LED ON.\n")
                #Code for enabling GPIO pin for light generation.     
            else:
                parts = incoming.split(',')
                if len(parts) == 2 and all(p.strip().isdigit() for p in parts): #If everything is number then map it
                    print("slave responding, Pong")
                    xVal, yVal = map(int, parts) # Converts each result into an int, very pythonic!
                    uart.write(f"{xVal},{yVal}\n")
                else:
                    print("fail")
                    uart.write("fail\n")
                    break
    else:
        print("Smthg happened lol\n")
    
time.sleep(0.5)

