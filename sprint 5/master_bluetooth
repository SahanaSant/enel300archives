from machine import Pin, ADC, UART, I2C
import utime
import time

uart = UART(0, baudrate=9600, tx=Pin(16), rx=Pin(17))
uart2 = UART(1, baudrate=9600, tx=Pin(8), rx=Pin(9))
xm = ADC(Pin(26))
ym = ADC(Pin(27))
button = Pin(22, Pin.IN, Pin.PULL_UP)

LOW_EDGE = 600
HIGH_EDGE = 60000


def send_at(command):
    """Send an AT command on UART0 and print the immediate reply.

    Parameters
    ----------
        command: str
            AT command string without trailing CRLF.

    Return
    ------
        None
    """
    uart.write(command + "\r\n")
    time.sleep(0.1)
    if uart.any():
        print(uart.read().decode("utf-8"))


def send_at2(command):
    """Send an AT command on UART1 and print the immediate reply.

    Parameters
    ----------
        command: str
            AT command string without trailing CRLF.

    Return
    ------
        None
    """
    uart2.write(command + "\r\n")
    time.sleep(0.1)
    if uart2.any():
        print(uart2.read().decode("utf-8"))


def build_bt_payload(x_val, y_val, button_val):
    """Build a payload compatible with slave_bluetooth.parse_bt_message.

    Parameters
    ----------
        x_val: int
            Raw joystick x-axis value.
        y_val: int
            Raw joystick y-axis value.
        button_val: int
            Button state where 0 means pressed.

    Return
    ------
        payload: str
            "pressed" or numeric "x,y" format.
    """
    x_dir = ""
    y_dir = ""

    if x_val <= LOW_EDGE:
        x_dir = "left"
    elif x_val >= HIGH_EDGE:
        x_dir = "right"

    if y_val <= LOW_EDGE:
        y_dir = "up"
    elif y_val >= HIGH_EDGE:
        y_dir = "down"

    if button_val == 0:
        return "pressed"
    if x_dir and y_dir:
        return "{},{}".format(x_val, y_val)
    if x_dir:
        return "{},0".format(x_val)
    if y_dir:
        return "0,{}".format(y_val)
    return "0,0"


def send_bt_payload(payload):
    """Send one control payload to the slave over UART1.

    Parameters
    ----------
        payload: str
            Payload generated by build_bt_payload.

    Return
    ------
        None
    """
    uart2.write(payload + "\n")


