    while True:
        x_val = xm.read_u16()
        y_val = ym.read_u16()
        button_val = button.value()

        act = build_bt_payload(x_val, y_val, button_val)
        print("master ping | TX:", act)
        send_bt_payload(act)

        utime.sleep(0.5)
