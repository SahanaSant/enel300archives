from machine import Pin, PWM
from time import sleep

# Interactive calibration script for a 2-motor differential drive using an L298N.
# Run from a REPL/serial terminal so input() prompts work.
#
# What it measures:
# 1) Breakaway (minimum PWM) for each motor in forward/reverse
# 2) Straight-driving gain ratio (Motor B relative to Motor A) for forward/reverse
#
# Output:
# A copy/paste CAL dictionary you can paste into your main drive code.


# === L298N Motor Driver Pins ===
# Motor A
motor_a_in1 = Pin(28, Pin.OUT)
motor_a_in2 = Pin(27, Pin.OUT)
motor_a_en = PWM(Pin(26))
motor_a_en.freq(1000)

# Motor B
motor_b_in3 = Pin(13, Pin.OUT)
motor_b_in4 = Pin(14, Pin.OUT)
motor_b_en = PWM(Pin(15))
motor_b_en.freq(1000)


# === Calibration Test Settings ===
PULSE_TIME_S = 0.35       # Pulse length for breakaway tests
COOLDOWN_S = 0.40         # Pause between pulses/tests
STRAIGHT_TEST_TIME_S = 1.8
STRAIGHT_BASE_CMD = 40    # Base command percent for straight test
RATIO_MIN = 0.70
RATIO_MAX = 1.30
RATIO_STEPS = 6           # Binary-search iterations for straight trim


def clamp(value, low, high):
    return max(low, min(high, value))


def pct_to_u16(percent):
    percent = clamp(percent, 0, 100)
    return int(percent * 65535 / 100)


def stop_all():
    motor_a_in1.value(0)
    motor_a_in2.value(0)
    motor_b_in3.value(0)
    motor_b_in4.value(0)
    motor_a_en.duty_u16(0)
    motor_b_en.duty_u16(0)


def set_motor(motor, direction="stop", speed=0):
    speed = clamp(int(speed), 0, 100)

    if motor == "A":
        if direction == "forward":
            motor_a_in1.value(0)
            motor_a_in2.value(1)
        elif direction == "backward":
            motor_a_in1.value(1)
            motor_a_in2.value(0)
        else:
            motor_a_in1.value(0)
            motor_a_in2.value(0)
            speed = 0
        motor_a_en.duty_u16(pct_to_u16(speed))

    elif motor == "B":
        if direction == "forward":
            motor_b_in3.value(1)
            motor_b_in4.value(0)
        elif direction == "backward":
            motor_b_in3.value(0)
            motor_b_in4.value(1)
        else:
            motor_b_in3.value(0)
            motor_b_in4.value(0)
            speed = 0
        motor_b_en.duty_u16(pct_to_u16(speed))


def pulse_motor(motor, direction, speed, seconds=PULSE_TIME_S):
    stop_all()
    sleep(COOLDOWN_S)
    set_motor(motor, direction, speed)
    sleep(seconds)
    stop_all()
    sleep(COOLDOWN_S)


def run_straight(direction, left_cmd, right_cmd, seconds=STRAIGHT_TEST_TIME_S):
    stop_all()
    sleep(COOLDOWN_S)
    set_motor("A", direction, left_cmd)
    set_motor("B", direction, right_cmd)
    sleep(seconds)
    stop_all()
    sleep(COOLDOWN_S)


def ask_yes_no(prompt):
    while True:
        ans = input(prompt + " [y/n]: ").strip().lower()
        if ans in ("y", "yes"):
            return True
        if ans in ("n", "no"):
            return False
        print("Please enter y or n.")


def ask_choice(prompt, valid):
    valid_set = set(valid)
    while True:
        ans = input(prompt).strip().lower()
        if ans in valid_set:
            return ans
        print("Valid options:", ", ".join(valid))


def wait_enter(msg):
    input(msg + " (press Enter) ")


def find_breakaway(motor, direction):
    print("")
    print("Breakaway test:", motor, direction)
    print("Put the robot on the normal surface with normal load.")
    print("Judge 'yes' only if the wheel/robot starts moving immediately during the pulse.")

    lo = 0
    hi = 100

    while lo < hi:
        mid = (lo + hi) // 2
        print("Testing PWM {}%".format(mid))
        pulse_motor(motor, direction, mid)
        moved = ask_yes_no("Did it start moving?")
        if moved:
            hi = mid
        else:
            lo = mid + 1

    print("Estimated breakaway for Motor {} {}: {}%".format(motor, direction, lo))
    return lo


def tune_straight_ratio(direction, base_cmd=STRAIGHT_BASE_CMD):
    print("")
    print("Straight ratio tuning:", direction)
    print("Robot will drive straight for {:.1f}s each run.".format(STRAIGHT_TEST_TIME_S))
    print("Motor A uses {}%. Motor B uses {}% * ratio.".format(base_cmd, base_cmd))
    print("Report drift based on the robot path:")
    print("  l = drifted left (right side too fast)")
    print("  r = drifted right (right side too slow)")
    print("  s = straight enough")

    low = RATIO_MIN
    high = RATIO_MAX
    best = 1.0

    for i in range(RATIO_STEPS):
        ratio = (low + high) / 2.0
        right_cmd = clamp(int(round(base_cmd * ratio)), 0, 100)

        print("")
        print("Run {}/{} with ratio {:.4f} (A={}%, B={}%)".format(
            i + 1, RATIO_STEPS, ratio, base_cmd, right_cmd
        ))
        wait_enter("Place robot at start line and clear space")
        run_straight(direction, base_cmd, right_cmd)

        result = ask_choice("Drift? [l/r/s]: ", ("l", "r", "s"))
        best = ratio

        if result == "s":
            print("Straight enough.")
            break
        if result == "l":
            # Drift left -> right motor too fast -> lower B ratio
            high = ratio
        else:
            # Drift right -> right motor too slow -> raise B ratio
            low = ratio

    print("Estimated Motor B ratio for {}: {:.4f}".format(direction, best))
    return best


def print_recommended_cal(a_fwd_min, a_rev_min, b_fwd_min, b_rev_min, b_fwd_gain, b_rev_gain):
    print("")
    print("=== Recommended calibration constants ===")
    print("CAL = {")
    print('    "A": {"fwd_gain": 1.0000, "rev_gain": 1.0000, "fwd_min": %d, "rev_min": %d},' % (a_fwd_min, a_rev_min))
    print('    "B": {"fwd_gain": %.4f, "rev_gain": %.4f, "fwd_min": %d, "rev_min": %d},' % (
        b_fwd_gain, b_rev_gain, b_fwd_min, b_rev_min
    ))
    print("}")
    print("")
    print("Notes:")
    print("- Re-run after battery type/voltage changes.")
    print("- Forward/reverse are calibrated separately because they usually differ.")


def main():
    print("L298N DC motor calibration helper")
    print("This script is interactive and requires serial/REPL input.")
    print("")
    print("Safety:")
    print("- Lift the robot for initial checks, then use normal floor/load for calibration.")
    print("- Keep fingers/clothes clear of wheels.")

    wait_enter("Ready to begin")

    # Breakaway PWM calibration
    a_fwd_min = find_breakaway("A", "forward")
    a_rev_min = find_breakaway("A", "backward")
    b_fwd_min = find_breakaway("B", "forward")
    b_rev_min = find_breakaway("B", "backward")

    # Straight ratio (B relative to A)
    print("")
    do_straight = ask_yes_no("Run straight-driving gain calibration too?")
    if do_straight:
        b_fwd_gain = tune_straight_ratio("forward")
        b_rev_gain = tune_straight_ratio("backward")
    else:
        b_fwd_gain = 1.0
        b_rev_gain = 1.0

    print_recommended_cal(
        a_fwd_min, a_rev_min,
        b_fwd_min, b_rev_min,
        b_fwd_gain, b_rev_gain
    )

    stop_all()


try:
    main()
finally:
    stop_all()

